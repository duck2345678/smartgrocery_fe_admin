# =========================================================================
# SmartGrocery Admin Web Dashboard Configuration Template (.env.example)
# Hướng dẫn: Sao chép tệp này thành '.env' và điền URL API của bạn.
# =========================================================================

# Địa chỉ URL API của Backend Spring Boot
# Mặc định ở môi trường local là http://localhost:8080
# Các biến môi trường trong Vite bắt buộc phải bắt đầu bằng tiền tố 'VITE_'
VITE_API_URL=http://localhost:8080
